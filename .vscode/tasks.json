{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "setup: markitdown",
            "type": "shell",
            "command": "pipx install markitdown",
            "presentation": {
                "panel": "dedicated",
                "reveal": "always",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "proxy: claude-nim",
            "type": "shell",
            "command": "cd ${workspaceFolder}/scripts/nim/ && ./run-claude-nim-proxy.sh",
            "isBackground": true,
            "problemMatcher": {
                "owner": "claude-nim",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^INFO:\\s+Started server process",
                    "endsPattern": "^INFO:\\s+Uvicorn running on"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "proxy: litellm",
            "type": "shell",
            "command": "cd ${workspaceFolder}/scripts/nim/ && ./run-litellm-proxy.sh",
            "isBackground": true,
            "problemMatcher": {
                "owner": "litellm",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^INFO:\\s+Started server process",
                    "endsPattern": "^INFO:\\s+Uvicorn running on"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "start: aspire-dashboard",
            "type": "shell",
            "command": "docker run --rm -p 18888:18888 -p 4317:18889 mcr.microsoft.com/dotnet/aspire-dashboard",
            "isBackground": true,
            "problemMatcher": {
                "owner": "aspire-dashboard",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*docker.*",
                    "endsPattern": "^\\s*Login to the dashboard at.*$"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        },
        {
            "label": "build: backend",
            "type": "shell",
            "command": "dotnet build ${workspaceFolder}/backend/",
            "group": "build",
            "presentation": {
                "panel": "dedicated",
                "reveal": "silent",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "start: hub",
            "type": "shell",
            "command": "cd ${workspaceFolder}/backend && dotnet run --project src/Grimoire.Hub/",
            "isBackground": true,
            "presentation": {
                "panel": "dedicated",
                "reveal": "always"
            },
            "problemMatcher": {
                "owner": "hub",
                "pattern": {
                    "regexp": "."
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*[Bb]uilding.*$",
                    "endsPattern": "^.*Now listening on:.*$"
                }
            }
        },
        {
            "label": "start: frontend",
            "type": "shell",
            "command": "cd ${workspaceFolder}/frontend && bun run dev",
            "isBackground": true,
            "presentation": {
                "panel": "dedicated",
                "reveal": "always"
            },
            "problemMatcher": {
                "owner": "frontend",
                "pattern": {
                    "regexp": "."
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*starting.*$",
                    "endsPattern": "^.*(ready in|Local:).*$"
                }
            }
        },
        {
            "label": "prelaunch: noproxy",
            "dependsOn": [
                "start: aspire-dashboard",
                "build: backend",
                "start: frontend"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": []
        },
        {
            "label": "prelaunch: proxy",
            "dependsOn": [
                "proxy: litellm",
                "start: aspire-dashboard",
                "build: backend",
                "start: frontend"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": []
        }
    ]
}