ANTHROPIC_AUTH_TOKEN=sk-ant-oat01
GRIMOIRE_INGEST_MODEL="claude-haiku-4-5"
# GRIMOIRE_INGEST_BASE_URL="https://api.anthropic.com"

GRIMOIRE_INGEST_TOKEN_CAP=1000000

NVIDIA_API_KEY=nvapi-
NVIDIA_MODEL=minimaxai/minimax-m3

# Agent evals against the affordable NVIDIA NIM provider (feature 007), via the project's
# LiteLLM proxy (scripts/nim/run-litellm-proxy.sh + scripts/nim/litellm_config.yaml).
# Start the proxy first, then set these three to run `dotnet test backend/tests/Grimoire.AgentEvals`
# without an Anthropic subscription. See specs/007-eval-tests-nim-endpoint/quickstart.md.
# GRIMOIRE_EVAL=1
# GRIMOIRE_EVAL_PROVIDER_BASE_URL="http://localhost:4000"
# GRIMOIRE_EVAL_PROVIDER_MODEL="nvidia-model"
# GRIMOIRE_EVAL_PROVIDER_API_KEY="${NVIDIA_API_KEY}"

# Recorded-replay eval seam (feature 009, ADR-011): the Grimoire.IngestAgent composition
# root selects the model adapter from these. Production leaves BOTH unset. Setting both
# at once is a fail-fast configuration error. Normally only the EvalRunner sets these,
# per spawned sample — they are documented here for manual diagnosis only.
# GRIMOIRE_MODEL_REPLAY_PATH="/path/to/sample-01.json"   # replay a recording, no credential needed
# GRIMOIRE_MODEL_CAPTURE_PATH="/path/to/sample-01.json"  # capture live turns to a recording
