{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "IncludeScopes": true,
      "TimestampFormat": "yyyy-MM-ddTHH:mm:ss.fffffffZ"
    }
  },
  "GrimoireDb": {
    "Path": "./grimoire.db"
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ConsoleExporter": true
  }
}
